<!-- ========== JAVASCRIPT ========== -->
<script is:inline>
(function() {
  'use strict';

  /* --------------------------------------------------
     1. Scroll-Triggered Reveal Animations
  -------------------------------------------------- */
  const revealObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');

        // Stagger children animations
        const children = entry.target.querySelectorAll('.step-card, .testimonial-card, .struggle__card, .program-card');
        children.forEach(function(child, index) {
          child.style.animationDelay = (index * 0.15) + 's';
          child.style.transitionDelay = (index * 0.15) + 's';
        });

        revealObserver.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -40px 0px'
  });

  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(function(el) {
    revealObserver.observe(el);
  });

  // Also stagger direct sibling reveal elements within grids
  const grids = document.querySelectorAll('.steps__grid, .testimonials__grid, .struggle__grid, .programs__grid');
  grids.forEach(function(grid) {
    const cards = grid.querySelectorAll('.reveal');
    cards.forEach(function(card, index) {
      card.style.transitionDelay = (index * 0.12) + 's';
    });
  });


  /* --------------------------------------------------
     2. Navbar Scroll Effect
  -------------------------------------------------- */
  var nav = document.querySelector('nav, .navbar, .site-nav');
  var lastScrollY = 0;

  if (nav) {
    window.addEventListener('scroll', function() {
      var scrollY = window.pageYOffset || document.documentElement.scrollTop;

      if (scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }

      lastScrollY = scrollY;
    }, { passive: true });
  }


  /* --------------------------------------------------
     3. Smooth Scroll for Anchor Links
  -------------------------------------------------- */
  document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
    anchor.addEventListener('click', function(e) {
      var targetId = this.getAttribute('href');
      if (targetId === '#') return;

      var target = document.querySelector(targetId);
      if (target) {
        e.preventDefault();
        var navHeight = nav ? nav.offsetHeight : 0;
        var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - navHeight;

        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
      }
    });
  });


  /* --------------------------------------------------
     4. Mobile Menu Toggle
  -------------------------------------------------- */
  var menuToggle = document.querySelector('#hamburger, .nav__hamburger');
  var mobileMenu = document.querySelector('#mobileMenu, .nav__mobile-menu');

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', function() {
      menuToggle.classList.toggle('active');
      mobileMenu.classList.toggle('active');
      document.body.classList.toggle('menu-open');
    });

    // Close menu when a nav link is clicked
    mobileMenu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menuToggle.classList.remove('active');
        mobileMenu.classList.remove('active');
        document.body.classList.remove('menu-open');
      });
    });
  }


  /* --------------------------------------------------
     5. Parallax Effect on Hero Background
  -------------------------------------------------- */
  var heroSection = document.querySelector('.hero, .hero-section');
  var heroBg = heroSection ? heroSection.querySelector('.hero-bg, .hero-background, .hero-image') : null;

  if (heroBg) {
    var ticking = false;

    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(function() {
          var scrollY = window.pageYOffset || document.documentElement.scrollTop;
          var heroHeight = heroSection.offsetHeight;

          if (scrollY <= heroHeight) {
            heroBg.style.transform = 'translateY(' + (scrollY * 0.35) + 'px) scale(1.1)';
          }

          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  // Parallax for Getting Started section background
  var gettingStartedSection = document.querySelector('.getting-started-section');
  var gettingStartedBg = gettingStartedSection ? gettingStartedSection.querySelector('.getting-started-bg') : null;

  if (gettingStartedBg) {
    var gsTicking = false;

    window.addEventListener('scroll', function() {
      if (!gsTicking) {
        window.requestAnimationFrame(function() {
          var rect = gettingStartedSection.getBoundingClientRect();
          var sectionHeight = gettingStartedSection.offsetHeight;
          var windowHeight = window.innerHeight;

          if (rect.top < windowHeight && rect.bottom > 0) {
            var progress = (windowHeight - rect.top) / (windowHeight + sectionHeight);
            gettingStartedBg.style.transform = 'translateY(' + ((progress - 0.5) * 60) + 'px) scale(1.1)';
          }

          gsTicking = false;
        });
        gsTicking = true;
      }
    }, { passive: true });
  }


  /* --------------------------------------------------
     6. Testimonials Auto-Scroll (Gentle Horizontal)
  -------------------------------------------------- */
  var testimonialsGrid = document.querySelector('.testimonials__grid');

  if (testimonialsGrid) {
    var autoScrollSpeed = 0.5;     // pixels per frame
    var autoScrollPaused = false;
    var autoScrollDirection = 1;

    // Pause on hover or touch
    testimonialsGrid.addEventListener('mouseenter', function() {
      autoScrollPaused = true;
    });
    testimonialsGrid.addEventListener('mouseleave', function() {
      autoScrollPaused = false;
    });
    testimonialsGrid.addEventListener('touchstart', function() {
      autoScrollPaused = true;
    }, { passive: true });
    testimonialsGrid.addEventListener('touchend', function() {
      setTimeout(function() { autoScrollPaused = false; }, 2000);
    }, { passive: true });

    function autoScrollTestimonials() {
      if (!autoScrollPaused && testimonialsGrid.scrollWidth > testimonialsGrid.clientWidth) {
        var maxScroll = testimonialsGrid.scrollWidth - testimonialsGrid.clientWidth;

        testimonialsGrid.scrollLeft += autoScrollSpeed * autoScrollDirection;

        // Reverse direction at boundaries
        if (testimonialsGrid.scrollLeft >= maxScroll - 1) {
          autoScrollDirection = -1;
        } else if (testimonialsGrid.scrollLeft <= 1) {
          autoScrollDirection = 1;
        }
      }

      requestAnimationFrame(autoScrollTestimonials);
    }

    // Only start auto-scroll if the grid overflows (i.e., acts as a carousel)
    var checkOverflow = function() {
      if (testimonialsGrid.scrollWidth > testimonialsGrid.clientWidth) {
        requestAnimationFrame(autoScrollTestimonials);
      }
    };

    // Delay check to let layout settle
    if (document.readyState === 'complete') {
      checkOverflow();
    } else {
      window.addEventListener('load', checkOverflow);
    }
  }


  /* --------------------------------------------------
     7. Counter Animation for Numbers
  -------------------------------------------------- */
  function animateCounters() {
    var counters = document.querySelectorAll('[data-count]');

    var counterObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var target = parseInt(el.getAttribute('data-count'), 10);
          var duration = 2000;
          var startTime = null;
          var startValue = 0;

          function updateCounter(timestamp) {
            if (!startTime) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / duration, 1);

            // Ease-out cubic
            var easedProgress = 1 - Math.pow(1 - progress, 3);
            var current = Math.floor(startValue + (target - startValue) * easedProgress);

            el.textContent = current.toLocaleString();

            if (progress < 1) {
              requestAnimationFrame(updateCounter);
            } else {
              el.textContent = target.toLocaleString();
            }
          }

          requestAnimationFrame(updateCounter);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(function(counter) {
      counterObserver.observe(counter);
    });
  }

  animateCounters();


})();

</script>

